{
  "name": "examlab",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5174",
    "dev:lernen": "VITE_APP_MODE=lernen vite --port 5175",
    "build": "tsc -b && vite build",
    "build:lernen": "VITE_APP_MODE=lernen tsc -b && VITE_APP_MODE=lernen vite build --outDir dist-lernen",
    "lint": "eslint .",
    "lint:as-any": "../scripts/audit-as-any.sh --strict",
    "lint:musterloesung": "../scripts/audit-musterloesung.sh --strict",
    "lint:no-alert": "../scripts/audit-no-alert.sh --strict",
    "lint:no-tests-dir": "../scripts/audit-test-locations.sh --strict",
    "lint:wire-contract": "node ../scripts/audit-wire-contract.mjs --strict",
    "lint:no-emoji": "node ../scripts/audit-no-emoji.mjs --strict",
    "lint:no-inline-svg": "node ../scripts/audit-no-inline-svg.mjs --strict",
    "lint:typo-tokens": "node ../scripts/audit-typo-tokens.mjs --strict",
    "lint:storybook-coverage": "node ../scripts/audit-storybook-coverage.mjs --strict",
    "lint:react-doctor-state": "node ../scripts/audit-react-doctor-state.mjs --strict",
    "preview": "vite preview",
    "preview:lernen": "VITE_APP_MODE=lernen vite preview --outDir dist-lernen",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci-check": "npm run lint:as-any && npm run lint:no-alert && npm run lint:no-tests-dir && npm run lint:musterloesung && npm run lint:wire-contract && npm run lint:no-emoji && npm run lint:no-inline-svg && npm run lint:typo-tokens && npm run lint:storybook-coverage && npm run lint:react-doctor-state && npm test && npm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "postinstall": "cd .. && git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.40.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@gymhofwil/shared": "*",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-virtual": "^3.13.24",
    "@tiptap/extension-bullet-list": "^2.25.0",
    "@tiptap/extension-ordered-list": "^2.25.0",
    "@tiptap/extension-placeholder": "^2.27.2",
    "@tiptap/extension-underline": "^2.25.0",
    "@tiptap/react": "^2.25.0",
    "@tiptap/starter-kit": "^2.25.0",
    "@types/katex": "^0.16.8",
    "codemirror": "^6.0.2",
    "docx": "^9.6.1",
    "dompurify": "^3.3.3",
    "idb-keyval": "^6.2.2",
    "katex": "^0.16.44",
    "lucide-react": "^1.14.0",
    "pdfjs-dist": "^5.5.207",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.14.0",
    "tailwindcss": "^4.2.1",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@storybook/addon-docs": "^10.4.0",
    "@storybook/react-vite": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.0.5",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "fake-indexeddb": "^6.2.5",
    "globals": "^16.5.0",
    "jsdom": "^29.0.1",
    "storybook": "^10.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "react-doctor": "0.2.10",
    "vitest": "^4.1.2"
  }
}
