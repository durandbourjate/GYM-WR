#!/usr/bin/env bash
#
# pre-push Hook — blockt Push wenn ci-check failed.
# Setup: `git config core.hooksPath .githooks` (einmal pro Clone).
#
# Reason: GitHub Actions hat einen separaten `npm ci`-Step für `packages/shared/`
# der lokal NICHT in `cd ExamLab && npm run ci-check` enthalten ist. Plus
# `tsc -b` ist strikter als `tsc --noEmit` (Memory `feedback_pre_push_ci_check.md`).
# Pre-Push-Hook fängt beide Klassen von Drift.
#
# Override (für Notfälle): git push --no-verify

# Skip bei reinem Delete-Push: git push --delete schickt local_oid=000... auf stdin.
# Bei Mixed-Push (Delete + Code) Hook trotzdem laufen lassen. Stdin-Format laut
# git-hooks(5): "<local_ref> <local_oid> <remote_ref> <remote_oid>" pro Ref.
ZERO_OID="0000000000000000000000000000000000000000"
any_refs=false
all_deletes=true
while read local_ref local_oid remote_ref remote_oid; do
  any_refs=true
  if [ "$local_oid" != "$ZERO_OID" ]; then
    all_deletes=false
  fi
done

if $any_refs && $all_deletes; then
  echo "🔍 pre-push: skip ci-check (alle refs sind Deletes)"
  exit 0
fi

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
echo "🔍 pre-push: checking packages/shared lock-sync + Planer vitest + ExamLab ci-check..."

# Step 1: packages/shared package-lock.json synchron mit package.json?
# `npm ci --dry-run` failt mit "Missing: X from lock file" bei Drift.
cd "$REPO_ROOT/packages/shared"
if ! npm ci --dry-run --silent > /dev/null 2>&1; then
  echo "❌ packages/shared: package-lock.json NICHT synchron mit package.json"
  echo "   Fix: cd packages/shared && npm install, dann beide Files committen."
  exit 1
fi

# Step 2: Unterrichtsplaner vitest-Tests.
cd "$REPO_ROOT/Unterrichtsplaner"
echo "🔍 pre-push: Unterrichtsplaner vitest..."
if ! npm test; then
  echo "❌ Unterrichtsplaner: vitest-Tests fehlgeschlagen. Push blockiert."
  echo "   Override (mit Vorsicht): git push --no-verify"
  exit 1
fi

# Step 3: Volle ci-check-Pipeline (lints + tsc -b + vitest + build).
cd "$REPO_ROOT/ExamLab"
if ! npm run ci-check; then
  echo ""
  echo "❌ ExamLab ci-check failed. Push blockiert."
  echo "   Override (mit Vorsicht): git push --no-verify"
  exit 1
fi

echo "✅ pre-push: lock-sync + Planer vitest + ExamLab ci-check clean."
