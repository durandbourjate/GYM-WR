{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "baseUrl": ".",
    "paths": {
      "@dnd-kit/core": ["../../ExamLab/node_modules/@dnd-kit/core"],
      "@dnd-kit/sortable": ["../../ExamLab/node_modules/@dnd-kit/sortable"],
      "@dnd-kit/utilities": ["../../ExamLab/node_modules/@dnd-kit/utilities"],
      "lucide-react": ["../../ExamLab/node_modules/lucide-react"],
      "zustand": ["../../ExamLab/node_modules/zustand"]
    }
  },
  "include": ["src"]
}
